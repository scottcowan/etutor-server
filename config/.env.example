# Server
HOST=0.0.0.0
PORT=8000
SECRET_KEY=change-me-to-a-long-random-string

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/etutor.db

# STT — pick one
STT_PROVIDER=local                        # local | openai
WHISPER_MODEL=base.en                     # base.en | small.en | large-v3
# OPENAI_API_KEY=sk-...                   # needed if STT_PROVIDER=openai

# Inference — litellm routes these
INFERENCE_MODEL=claude-sonnet-5           # or gpt-4o or ollama/gemma2:12b
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Calibre-Web — Synology NAS rs816
CALIBRE_WEB_URL=http://192.168.0.25:8083
CALIBRE_WEB_ADMIN_USER=admin
CALIBRE_WEB_ADMIN_PASSWORD=

# Age group model routing
# Younger children get a faster/cheaper model; older get the full model
MODEL_UNDER_8=claude-haiku-4-5-20251001
MODEL_8_PLUS=claude-sonnet-5
